# =============================================================================
# prosperofy-app — local overrides (gitignored pattern: .env.local)
# Same variables as .env.example; use this file for machine-specific URLs.
# API contract (envelope, headers, CORS): ../prosperofy-laravel-core/docs/api/FRONTEND.md
# =============================================================================

NODE_ENV=production
# Laravel API origin only; trim whitespace; do not append /api.
# Laravel API origin only (MUST NOT include /api suffix)
NEXT_PUBLIC_LARAVEL_API_BASE_URL=https://backend.prosperofy.com
# Local Next dev against this host: add http://127.0.0.1:3000,http://localhost:3000 to Laravel CORS_ALLOWED_ORIGINS.
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Full reference: see .env.example for production values (https://app.prosperofy.com, etc.).
