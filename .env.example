# =============================================================================
# prosperofy-app — production-oriented template
# Public site: https://app.prosperofy.com
# Browser calls Laravel only — never point NEXT_PUBLIC_* at aiservice or walletapi.
# Agents UI uses /api/app/agents/* only; do NOT add NEXT_PUBLIC_AI_* or NEXT_PUBLIC_*_API_KEY here.
# FORBIDDEN in public env: NEXT_PUBLIC_WALLET_SERVICE_URL, service keys, encryption keys, mnemonics.
# DigitalOcean App Platform: set as build-time + runtime env for Next.js.
# API contract (envelope, headers, CORS): ../prosperofy-laravel-core/docs/api/FRONTEND.md
# =============================================================================

# WFL Wallet UI flags (mirror Laravel WALLET_SEND_*)
NEXT_PUBLIC_WALLET_SEND_SOLANA_ENABLED=true
NEXT_PUBLIC_WALLET_SEND_SPL_ENABLED=false
NEXT_PUBLIC_WALLET_SEND_ETHEREUM_ENABLED=false
NEXT_PUBLIC_WALLET_SEND_BITCOIN_ENABLED=false
NEXT_PUBLIC_WALLET_SEND_ERC20_ENABLED=false

NODE_ENV=production
PORT=3000

APP_URL=https://app.prosperofy.com
NEXT_PUBLIC_APP_URL=https://app.prosperofy.com
SERVICE_URL=https://app.prosperofy.com

# Laravel API origin only (MUST NOT include /api suffix)
NEXT_PUBLIC_LARAVEL_API_BASE_URL=https://backend.prosperofy.com
# Agent run / signal generate (align with Laravel AI_SERVICE_TIMEOUT ~120s)
# NEXT_PUBLIC_AGENT_TIMEOUT_MS=150000
# Optional alias read by src/lib/api/client.ts if LARAVEL var is unset:
# NEXT_PUBLIC_API_BASE_URL=https://backend.prosperofy.com
API_BASE_URL=https://backend.prosperofy.com
BACKEND_URL=https://backend.prosperofy.com

FRONTEND_URL=https://app.prosperofy.com
BACKOFFICE_URL=https://backoffice.prosperofy.com
DEVELOPER_PORTAL_URL=https://developer.prosperofy.com

CORS_ORIGINS=https://prosperofy.com,https://www.prosperofy.com,https://app.prosperofy.com,https://backoffice.prosperofy.com,https://developer.prosperofy.com
ALLOWED_ORIGINS=https://prosperofy.com,https://www.prosperofy.com,https://app.prosperofy.com,https://backoffice.prosperofy.com,https://developer.prosperofy.com

CALLBACK_URL=https://app.prosperofy.com/auth/callback
REDIRECT_URL=https://app.prosperofy.com/dashboard
AUTH_URL=https://backend.prosperofy.com
TRUSTED_HOSTS=app.prosperofy.com

# Optional: hosting platform env for dashboard dev banners (e.g. Vercel).
# NEXT_PUBLIC_VERCEL_ENV=production

# --- Local development example (copy to .env.local) ---
# NODE_ENV=development
# NEXT_PUBLIC_LARAVEL_API_BASE_URL=http://127.0.0.1:8080
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
